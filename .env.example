# Copy to .env.local and fill in. Never commit real secrets.

# Public site URL (no trailing slash) — used for Open Graph / social preview URLs in production
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# From the spreadsheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Recommended (Windows-friendly): base64-encode the entire downloaded *.json file (no line breaks),
# then paste here. PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("path\to\key.json"))
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Alternative: entire JSON on ONE line. In .env use single quotes so inner " do not break parsing:
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...",...}'

# Append range: your tab name + columns (row 1 = headers: Timestamp, Email, Role, Phone, Services).
# Example shape: <TabName>!A:E — set to match your spreadsheet (do not commit real values if Netlify scans secrets).
GOOGLE_SHEETS_RANGE=
